  </section>

  <!-- ============================================================
       HOW WE WORK — alternating sides with connecting line
       ============================================================ -->
  <section class="section how-section reveal">
    <h2 class="how-heading">How we work together</h2>
    <div class="how-steps">
      {howSteps.map((step, i) => (
        <article class={`step ${i % 2 === 0 ? "step--right" : "step--left"}`}>
          <div class="step__num">{i + 1}</div>
          <div class="step__content">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ============================================================
       PACKAGES — single pricing card with tier selector
       ============================================================ -->
  <section class="section packages-section reveal">
    <div class="packages-header">
      <div class="packages-header__title">
        <div class="section-label">Packages</div>
        <h2 class="packages-heading">
          Pricing that supports <span
            data-title-part
            data-artists="independent artists"
            data-brands="emerging brands"
            data-creators="solo creators"
          >independent artists</span>
        </h2>
      </div>
      <p class="packages-caption">
        g10s' reason to exist is to support <span
          data-title-part
          data-artists="artists"
          data-brands="brands"
          data-creators="creators"
        >artists</span> with less resources to stand up against larger competitors. I'll handle all the hard parts of web and app development, and give you tools where you can get hands on. You build high-grade tech with me as a seasoned product engineer on your side.
      </p>
    </div>

    <div class="pricing-card pricing-card--featured pricing-card--single" data-pricing-card data-tier="1">
      <div class="tier-selector" role="radiogroup" aria-label="Choose your plan">
        <div class="tier-selector__label">Choose your package</div>
        <div class="tier-selector__buttons">
          {tiers.map((t, i) => (
            <button
              type="button"
              class={`tier-btn${i === 1 ? " is-active" : ""}`}
              data-tier-btn={i}
              role="radio"
              aria-checked={i === 1 ? "true" : "false"}
            >
              <span class="tier-btn__name">{t.name}</span>
              <span class="tier-btn__desc">{t.description}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="benefits-table" role="table" aria-label="Package benefits">
        <div class="benefits-table__head" role="row">
          <span role="columnheader" aria-label="Benefit"></span>
          <span role="columnheader">DIY</span>
          <span role="columnheader">Agency</span>
        </div>
        {benefits.map((b) => {
          const initial = b.incl[1];
          const hasBadge = initial !== "yes" && initial !== "no";
          return (
            <div
              class={`benefits-table__row${initial === "no" ? " is-excluded" : ""}`}
              data-incl={JSON.stringify(b.incl)}
              role="row"
            >
              <span class="benefits-table__name">
                <span class="benefits-table__name-text">{b.name}</span>
                <span class="benefits-table__badge" data-badge>{hasBadge ? initial : ""}</span>
              </span>
              <span class="benefits-table__cost" data-col="diy">{b.diy}</span>
              <span class="benefits-table__cost benefits-table__cost--agency" data-col="agency">{b.agency}</span>
            </div>
          );
        })}
      </div>

      <div class="pricing-totals">
        <!-- Row 1: totals for competitor options, introduced on the left -->
        <div class="pricing-total pricing-total--totals-label">
          <span class="pricing-total__label">Total:</span>
        </div>
        <div class="pricing-total pricing-total--totals-diy">
          <div class="pricing-total__value pricing-total__value--time" data-total-diy>{tiers[1].diySummary}</div>
        </div>
        <div class="pricing-total pricing-total--totals-agency">
          <div class="pricing-total__value pricing-total__value--strike" data-total-agency>{tiers[1].agencySummary}</div>
        </div>
        <!-- Row 2: g10s offer, introduced on the left -->
        <div class="pricing-total--ours-bg" aria-hidden="true"></div>
        <div class="pricing-total pricing-total--ours-label">
          <span class="pricing-total__label">with g10s:</span>
        </div>
        <div class="pricing-total pricing-total--ours-value">
          <span class="pricing-total__ours-price" data-total-price>{tiers[1].price}</span>
          <span class="pricing-total__ours-sub" data-total-duration>{tiers[1].duration}</span>
          <span class="pricing-total__guarantee" data-total-guarantee>{tiers[1].moneyBack ? `${tiers[1].moneyBack} money-back guarantee` : ""}</span>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ tiersData: tiers }}>
    (function () {
      const card = document.querySelector("[data-pricing-card]");
      if (!card) return;
      const buttons = card.querySelectorAll("[data-tier-btn]");
      const rows = card.querySelectorAll(".benefits-table__row");
      const diyEl = card.querySelector("[data-total-diy]");
      const agencyEl = card.querySelector("[data-total-agency]");
      const priceEl = card.querySelector("[data-total-price]");
      const durationEl = card.querySelector("[data-total-duration]");
      const guaranteeEl = card.querySelector("[data-total-guarantee]");

      function render(tier) {
        card.dataset.tier = String(tier);
        buttons.forEach(function (btn, i) {
          const active = i === tier;
          btn.classList.toggle("is-active", active);
          btn.setAttribute("aria-checked", active ? "true" : "false");
        });

        rows.forEach(function (row) {
          let incl;
          try {
            incl = JSON.parse(row.dataset.incl || "[]");
          } catch (_) {
            incl = [];
          }
          const value = incl[tier];
          row.classList.toggle("is-excluded", value === "no");
          const badge = row.querySelector("[data-badge]");
          if (badge) badge.textContent = value === "yes" || value === "no" ? "" : value;
        });

        const t = tiersData[tier];
        diyEl.textContent = t.diySummary;
        agencyEl.textContent = t.agencySummary;
        priceEl.textContent = t.price;
        durationEl.textContent = t.duration;
        if (guaranteeEl) {
          guaranteeEl.textContent = t.moneyBack ? t.moneyBack + " money-back guarantee" : "";
        }
      }

      buttons.forEach(function (btn, i) {
        btn.addEventListener("click", function () {
          render(i);
        });
      });

      render(1);
    })();
  </script>

