---
import Base from "../layouts/Base.astro";
import CtaButton from "../components/CtaButton.astro";

const hero = {
  artists: {
    prefix: "Unique ",
    tag: "tech",
    mid: " for ",
    audience: "independent artists",
    italicPre: "to stick in ",
    contrast: "listener's minds",
    italicPost: ".",
    body: "I make custom-built digital experiences for independent artists, to help them stand out in a crowded market. Big labels pay $20K+ for this — I make it happen at a fraction.",
  },
  brands: {
    prefix: "Unique ",
    tag: "tech",
    mid: " for ",
    audience: "emerging brands",
    italicPre: "to earn ",
    contrast: "trust",
    italicPost: ".",
    body: "I make custom-built digital experiences for emerging brands, to help them stand out in a crowded market. Big names pay $20K+ for this — I make it happen at a fraction.",
  },
  creators: {
    prefix: "Unique ",
    tag: "tech",
    mid: " for ",
    audience: "solo creators",
    italicPre: "to deepen ",
    contrast: "connections",
    italicPost: ".",
    body: "I make custom-built digital experiences for solo creators, to help them stand out in a crowded market. Funded studios pay $20K+ for this — I make it happen at a fraction.",
  },
} as const;

const examples = {
  artists: [
    {
      title: "Open studio",
      desc: "A digital space where fans follow your creative process — not just the finished work.",
      tag: "Open studio",
      sku: "OS·001",
    },
    {
      title: "Release experience",
      desc: "A custom listening room or release experience that feels like your world.",
      tag: "Release experience",
      sku: "RX·002",
    },
    {
      title: "Participatory tool",
      desc: "A collaborative canvas where your audience creates within rules you define.",
      tag: "Participatory tool",
      sku: "PT·003",
    },
  ],
  brands: [
    {
      title: "Drop experience",
      desc: "A custom drop experience for artist collabs that actually matches your brand quality.",
      tag: "Drop experience",
      sku: "DR·001",
    },
    {
      title: "Collection archive",
      desc: "A living archive that turns every collaboration into a persistent chapter.",
      tag: "Collection archive",
      sku: "CA·002",
    },
    {
      title: "Artist platform",
      desc: "A roster platform where your artists accumulate profiles, releases, and press over time.",
      tag: "Artist platform",
      sku: "AP·003",
    },
  ],
  creators: [
    {
      title: "Community space",
      desc: "A private community space designed around how you actually connect with your people.",
      tag: "Community space",
      sku: "CS·001",
    },
    {
      title: "Creator platform",
      desc: "A custom platform that replaces the Patreon / Discord / Substack combo with something that's yours.",
      tag: "Creator platform",
      sku: "CP·002",
    },
    {
      title: "Audience tool",
      desc: "An audience tool built around your content philosophy.",
      tag: "Audience tool",
      sku: "AT·003",
    },
  ],
} as const;

type Project = {
  logo: string;
  title: string;
  summary?: string;
  body?: string;
  video?: string;
  embed?: "instagram";
  href?: string;
  cta?: string;
};

const projects: Project[] = [
  {
    logo: "/bb_logo.svg",
    title: "Batchbrew",
    summary: "Creative workspace with AI integrations",
    body: "Add inspiration and research to collaborative whiteboards and sync your data across all your devices. Automatically creates a searchable library for your curated saves. Built solo — competitors need 4-person teams for the same thing.",
    href: "https://batchbrew.xyz",
    cta: "Go to Batchbrew",
  },
  {
    logo: "/wave-sine.svg",
    title: "Camera Control Synthesizer",
    summary: "An instrument you play with your webcam",
    video: "https://cofzhirmlrbeifndntdo.supabase.co/storage/v1/object/public/product-images/g10s-services-assets/cam-controlled-synth.MOV",
  },
  {
    logo: "/scalable-logo.svg",
    title: "Scalable",
    summary: "From zero to the first 2,000 users",
    body: "Joined a non-technical founder as first engineer on a bootstrapped team. Built the technical foundation, shipped core features and security work, and was on board scaling from zero to the first 2,000 users.",
    href: "https://www.scalable.so/",
    cta: "Go to Scalable",
  },
  {
    logo: "/reelio-logo.svg",
    title: "Reelio",
    summary: "Deliver Netflix-quality videos to online stores.",
    body: "Video streaming infrastructure for ecommerce — adaptive bitrate, edge delivery, and a lightweight player tuned for product pages. Sold to a different owner in an early pre-revenue phase.",
    href: "https://reelio.io/",
    cta: "Go to Reelio",
  },
  {
    logo: "/hand-sparkles-filled.svg",
    title: "Gesture Controlled Whiteboard",
    summary: "Control your mood board with your web cam",
    body: "A UX experiment where I built out a touch-less UX concept for my whiteboard app. Users can pan, zoom and drag using their hands.",
    embed: "instagram",
    href: "https://www.instagram.com/p/DW3p7quDG0K/",
    cta: "Open on Instagram",
  },
];

type Review = {
  name: string;
  role: string;
  text: string;
  photo?: string;
  linkedin?: string;
  instagram?: string;
};

const reviews: Review[] = [
  {
    name: "Jacob",
    role: "Ecom branding, non-technical founder",
    photo: "/jacob.jpeg",
    linkedin: "https://www.linkedin.com/in/jvcob/",
    text: "I built Scalable with AI coding tools, but it was only after Giorgio joined that the code base got reliable and mature enough to support our first 2k sign ups. He brought serious technical ability to our team to launch our product off the ground and built core elements that helped establish our web app early on.",
  },
  {
    name: "Raoul",
    role: "Consultant",
    photo: "/raoul.jpeg",
    linkedin: "https://www.linkedin.com/in/raoul-schwagmeier/",
    text: "Our concept sessions were very eye opening; I started out with a big complicated idea, but Giorgio helped me to break it down and show me what and how to work on it.",
  },
  {
    name: "Lena",
    role: "IG creator, hospitality manager",
    photo: "/lena.jpg",
    instagram: "https://www.instagram.com/lenac.life/",
    text: "I had an idea for months to solve a specific problem I saw other hospitality managers running into. But I had no idea where to start. I was speaking to Giorgio and he worked out the concept with me in less than an hour. He saved me so much time and helped me bring my idea into fruition. Now I have a prototype and know exatly what to do next.",
  },
  {
    name: "Lars",
    role: "Running 7-fig e-commerce brand",
    photo: "/lars.jpeg",
    text: "Giorgio is the perfect sparring partner for comprehensive tech projects. Our idea turned out to be quite complicated, but Giorgio helped us break it down into parts we can actually go forward with and build. Our concept call with him was the deciding factor to get us from a rough ai-coded initial concept to creating a useful web app we can actually publish and distribute to our users.",
  },
];

const howSteps = [
  {
    title: "You bring the taste and creative direction",
    body: "You know your world better than anyone. You set the direction and ideas, I bring the technical ability to make it real.",
  },
  {
    title: "We simplify your idea down to the core",
    body: "Most ideas start big. I use my experience to help you cut the scope to the one thing that matters. One thing, done well.",
  },
  {
    title: "We build it together",
    body: "We work out the concept, and I set up a strong tech foundation for the first product version. The more you take over, the more money you save.",
  },
  {
    title: "You get the product, ready for hosting",
    body: "You get the code, detailed documentation, and my ai tools to make edits yourself. The only step left for you is to get it online, but I can help you do that with a guide or do it for you as an add-on.",
  },
];

type Tier = {
  key: string;
  name: string;
  description: string;
  price: string;
  duration: string;
  diySummary: string;
  agencySummary: string;
  moneyBack: string | null;
};

type InclValue = "yes" | "no" | string;

type Benefit = {
  name: string;
  diy: string;
  agency: string;
  incl: [InclValue, InclValue, InclValue];
};

const tiers: Tier[] = [
  {
    key: "blueprint",
    name: "Blueprint",
    description: "Full project outline, ready for you to take over",
    price: "€500",
    duration: "1wk",
    diySummary: "2–3wk",
    agencySummary: "€6–9K",
    moneyBack: "100%",
  },
  {
    key: "cobuild",
    name: "Co-Build",
    description: "I build the foundation, you build the experience",
    price: "€3,500",
    duration: "2wk",
    diySummary: "2–3mo",
    agencySummary: "€22–32K",
    moneyBack: "100%",
  },
  {
    key: "hands-off",
    name: "Hands-off",
    description: "I build it all for you",
    price: "from €10k",
    duration: "6wk+",
    diySummary: "4–7mo",
    agencySummary: "€42–55K",
    moneyBack: null,
  },
];

const benefits: Benefit[] = [
  { name: "Concept planning", diy: "5–6d", agency: "€2,000", incl: ["yes", "yes", "yes"] },
  { name: "Dev tooling & workflow setup", diy: "1-2d", agency: "€500", incl: ["yes", "yes", "yes"] },
  { name: "Market research & audience", diy: "3–5d", agency: "€2,200", incl: ["yes", "yes", "yes"] },
  { name: "Custom landing page + waitlist", diy: "1wk", agency: "€3,000", incl: ["yes", "yes", "yes"] },
  { name: "Solid tech foundation", diy: "1–2wk", agency: "€4,000", incl: ["no", "yes", "yes"] },
  { name: "First working version", diy: "1–2mo", agency: "€15,000", incl: ["no", "yes", "yes"] },
  { name: "Handoff + codebase ownership", diy: "—", agency: "rare", incl: ["no", "yes", "yes"] },
  { name: "Run it on the web", diy: "2–4mo", agency: "€15–25K", incl: ["no", "no", "yes"] },
];
---

<Base>
  <!-- ============================================================
       BRAND — fixed top-left logo
       ============================================================ -->
  <a href="/" class="brand" aria-label="g10s home">
    <span class="brand-mark" aria-hidden="true"></span>
  </a>

  <!-- ============================================================
       TAB BAR — sticky top (desktop) / fixed bottom (mobile)
       ============================================================ -->
  <div class="toggle-bar">
    <div class="toggle-group liquid-glass" role="tablist" aria-label="Audience">
      <span class="toggle-pill" aria-hidden="true"></span>
      <button type="button" class="toggle-btn active" data-tab="artists">Artists</button>
      <button type="button" class="toggle-btn" data-tab="brands">Brands</button>
      <button type="button" class="toggle-btn" data-tab="creators">Creators</button>
    </div>
  </div>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero">
    <h1 class="hero__title">
      {hero.artists.prefix}<span class="hero__tag">{hero.artists.tag}</span>{hero.artists.mid}<br><span
        class="hero__audience"
        data-title-part="audience"
        data-artists={hero.artists.audience}
        data-brands={hero.brands.audience}
        data-creators={hero.creators.audience}
      >{hero.artists.audience}</span><br><em><span
          data-title-part="italicPre"
          data-artists={hero.artists.italicPre}
          data-brands={hero.brands.italicPre}
          data-creators={hero.creators.italicPre}
        >{hero.artists.italicPre}</span><span
          data-title-part="contrast"
          data-artists={hero.artists.contrast}
          data-brands={hero.brands.contrast}
          data-creators={hero.creators.contrast}
        >{hero.artists.contrast}</span>{hero.artists.italicPost}</em>
    </h1>
    <p class="hero__body">
      <span data-content="artists">{hero.artists.body}</span>
      <span data-content="brands" style="display:none">{hero.brands.body}</span>
      <span data-content="creators" style="display:none">{hero.creators.body}</span>
    </p>
    <div>
      <CtaButton href="mailto:lab@g10s.xyz" />
    </div>
  </section>

  <!-- ============================================================
       CASE STUDIES — horizontal scroll row of project cards
       ============================================================ -->
  <section class="case-studies" aria-labelledby="case-studies-title">
    <p id="case-studies-title" class="case-studies__title">Case Studies</p>
    <div class="case-studies__track">
      <a
        href="https://mosaiic.xyz"
        target="_blank"
        rel="noopener noreferrer"
        class="case-card"
      >
        <img
          class="case-card__thumb"
          src="/mosaiic-thumb.webp"
          width="72"
          height="72"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="case-card__body">
          <span class="case-card__title case-card__title--mosaiic">
            mosaïc
          </span>
        </div>
      </a>

      <a href="/1-800-demo/" class="case-card">
        <img
          class="case-card__thumb"
          src="/1-800-demo/thumb.webp"
          width="72"
          height="72"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="case-card__body">
          <span class="case-card__title case-card__title--pixel">
            1-800 GIRLS
          </span>
        </div>
      </a>

      <a
        href="https://batchbrew.xyz"
        target="_blank"
        rel="noopener noreferrer"
        class="case-card"
      >
        <img
          class="case-card__thumb"
          src="/bb-lp/bb-lp-thumb.webp"
          width="72"
          height="72"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="case-card__body">
          <span class="case-card__title case-card__title--bb">
            <span class="case-card__title-bb-initial">B</span>atchbrew
          </span>
        </div>
      </a>

      <a href="/cirali/" class="case-card">
        <img
          class="case-card__thumb case-card__thumb--cirali"
          src="/cirali/thumb.webp"
          width="72"
          height="72"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <div class="case-card__body">
          <span class="case-card__title case-card__title--cirali">
            Cirali
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ============================================================
       DIFFERENTIATOR — single card with check-marked perks
       ============================================================ -->
  <section class="section differentiator-section reveal">
    <aside class="differentiator-card">
      <span class="differentiator-card__bars" aria-hidden="true">
        <span class="differentiator-card__bar differentiator-card__bar--primary"></span>
        <span class="differentiator-card__bar differentiator-card__bar--secondary"></span>
      </span>
      <h2 class="differentiator-card__title" aria-label="g10s works a bit different">
        <span class="differentiator-card__logo" aria-hidden="true">
          <img src="/g10s_logo_pixels_bold.svg" alt="" />
        </span>
        works a bit different
      </h2>
      <ul class="differentiator-card__list">
        <li class="differentiator-card__item">
          <span class="differentiator-card__check" aria-hidden="true">
            <svg width="8" height="8" viewBox="0 0 10 10">
              <path d="M2 5.2l2 2L8 3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>Get your first version fast, within a week</span>
        </li>
        <li class="differentiator-card__item">
          <span class="differentiator-card__check" aria-hidden="true">
            <svg width="8" height="8" viewBox="0 0 10 10">
              <path d="M2 5.2l2 2L8 3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>Save money by getting involved</span>
        </li>
        <li class="differentiator-card__item">
          <span class="differentiator-card__check" aria-hidden="true">
            <svg width="8" height="8" viewBox="0 0 10 10">
              <path d="M2 5.2l2 2L8 3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>Adjust your product, without coding skill</span>
        </li>
        <li class="differentiator-card__item">
          <span class="differentiator-card__check" aria-hidden="true">
            <svg width="8" height="8" viewBox="0 0 10 10">
              <path d="M2 5.2l2 2L8 3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>You own your code</span>
        </li>
      </ul>
    </aside>
  </section>

  <!-- ============================================================
       EXAMPLES — packaging-label cards
       ============================================================ -->
  <section class="section examples-section reveal">
    <h2 class="section-heading">Some stuff I could create for you</h2>

    {(["artists", "brands", "creators"] as const).map((key) => (
      <div class="package-grid" data-content={key} style={key === "artists" ? "" : "display:none"}>
        {examples[key].map((ex, i) => (
          <article class="package">
            <div class="package__visual package__visual--flower">
              {i === 0 ? (
                <div class="package__tulip-wrap">
                  <img class="package__tulip-img package__tulip-img--mesh" src="/tulip.webp" alt="" aria-hidden="true" />
                  <img class="package__tulip-img package__tulip-img--colored" src="/tulip-colored.webp" alt="" aria-hidden="true" />
                </div>
              ) : i === 1 ? (
                <div class="package__tulip-wrap package__tulip-wrap--dahlia">
                  <img class="package__tulip-img package__tulip-img--mesh" src="/dhalia.webp" alt="" aria-hidden="true" />
                  <img class="package__tulip-img package__tulip-img--colored" src="/dhalia-colored.webp" alt="" aria-hidden="true" />
                </div>
              ) : (
                <div class="package__tulip-wrap package__tulip-wrap--flip package__tulip-wrap--lily">
                  <img class="package__tulip-img package__tulip-img--mesh" src="/lily.webp" alt="" aria-hidden="true" />
                  <img class="package__tulip-img package__tulip-img--colored" src="/lily-colored.webp" alt="" aria-hidden="true" />
                </div>
              )}
              <span class="package__visual-meta">IMG·{String(i + 1).padStart(2, "0")}</span>
            </div>
            <div class="package__body">
              <div class="package__rows">
                <div class="package__row package__row--title">
                  <span class="package__row-key">Item</span>
                  <span class="package__row-val">{ex.title}</span>
                </div>
                <div class="package__row">
                  <span class="package__row-key">Spec</span>
                  <span class="package__row-val">{ex.desc}</span>
                </div>
              </div>
              <div class="package__foot">
                <div class="package__sku">{ex.sku}</div>
                <div class="package__barcode" aria-hidden="true"></div>
              </div>
            </div>
          </article>
        ))}
      </div>
    ))}

    <div class="examples-cta">
      <CtaButton href="mailto:lab@g10s.xyz" />
    </div>
  </section>

  <!-- ============================================================
       ABOUT — with projects on the right
       ============================================================ -->
  <section class="section about-section reveal">
    <div class="about-grid">
      <div class="about-content">
        <article class="about-tweet">
          <div class="about-photo" role="img" aria-label="Giorgio"></div>
          <div class="about-tweet__body-col">
            <header class="about-tweet__identity">
              <h2 class="about-tweet__name">Giorgio</h2>
              <span class="about-tweet__handle">@g10s.xyz</span>
            </header>
            <p class="about-tweet__body">
              Hi I'm Giorgio,
              <br /><br />
              I'm a product architect. I've built 6
              products from scratch, worked with 4 startup teams from early
              stage to thousands of users, and spent the last years studying
              what makes brands and creative culture feel alive. I love to build
              meaningful user experience and unique products that feel and function
              great. 
            </p>
          </div>
        </article>
      </div>

      <div class="about-projects">
        <div class="projects-label">What I made before</div>
        <div class="project-stack">
          {projects.map((p) => (
            <div class="project-card" data-embed={p.embed}>
              <button type="button" class="project-card__header" data-project-toggle>
                <span class="project-card__logo">
                  <img src={p.logo} alt="" aria-hidden="true" />
                </span>
                <div class="project-card__info">
                  <h3>{p.title}</h3>
                  {p.summary && <span>{p.summary}</span>}
                </div>
                <span class="project-card__icon" aria-hidden="true">+</span>
              </button>
              <div class="project-card__body">
                <div class="project-card__body-inner">
                  {p.video ? (
                    <div class="project-card__video">
                      <video
                        data-project-video
                        data-src={p.video}
                        preload="none"
                        controls
                        playsinline
                      ></video>
                    </div>
                  ) : (
                    <>
                      {p.body && <p>{p.body}</p>}
                      {p.embed === "instagram" && p.href && (
                        <div class="project-card__embed">
                          <blockquote
                            class="instagram-media"
                            data-instgrm-permalink={p.href}
                            data-instgrm-version="14"
                          >
                            <a href={p.href}>View on Instagram</a>
                          </blockquote>
                        </div>
                      )}
                    </>
                  )}
                  {p.href && p.cta && (
                    <div class="project-card__cta">
                      <a href={p.href} target="_blank" rel="noopener noreferrer">{p.cta}</a>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       REVIEWS — large centered title, cards
       ============================================================ -->
  <section class="section reviews-section reveal">
    <h2 class="reviews-heading">What others say</h2>
    <div class="reviews-grid">
      {reviews.map((r) => (
        <div class="review-card">
          <div class="review-card__top">
            {r.photo ? (
              <div
                class="review-card__photo review-card__photo--image"
                role="img"
                aria-label={r.name}
                style={`background-image: url(${r.photo});`}
              ></div>
            ) : (
              <div class="review-card__photo" aria-hidden="true"></div>
            )}
            <div class="review-card__identity">
              <div class="review-card__name">
                {r.name}
                {r.linkedin && (
                  <a
                    class="review-card__social"
                    href={r.linkedin}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`${r.name} on LinkedIn`}
                  >
                    <svg
                      viewBox="0 0 24 24"
                      width="14"
                      height="14"
                      aria-hidden="true"
                      focusable="false"
                    >
                      <path
                        fill="currentColor"
                        d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.66H9.34V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"
                      />
                    </svg>
                  </a>
                )}
                {r.instagram && (
                  <a
                    class="review-card__social review-card__social--ig"
                    href={r.instagram}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`${r.name} on Instagram`}
                  >
                    <svg
                      viewBox="0 0 24 24"
                      width="14"
                      height="14"
                      aria-hidden="true"
                      focusable="false"
                    >
