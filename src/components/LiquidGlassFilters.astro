---
// Liquid glass displacement filter — shared across the landing page and
// demo projects. The refraction is driven by a pre-baked displacement
// WebP (/liquid-map.webp) sampled via feImage and fed into
// feDisplacementMap. primitiveUnits="objectBoundingBox" lets the same
// map stretch cleanly across any pill size.
//
// Safari / iOS note: `backdrop-filter: url(#...)` is unsupported, so
// consuming styles must pair the url() filter with a plain
// `-webkit-backdrop-filter: blur() saturate()` fallback.
---

<svg
  width="0"
  height="0"
  aria-hidden="true"
  style="position:absolute;width:0;height:0;overflow:hidden;pointer-events:none;"
>
  <defs>
    <filter id="g10s-liquid-glass" primitiveUnits="objectBoundingBox">
      <feImage
        href="/liquid-map.webp"
        x="0"
        y="0"
        width="100%"
        height="100%"
        result="map"
        preserveAspectRatio="none"
      />
      <feGaussianBlur in="SourceGraphic" stdDeviation="0.01" result="blur" />
      <feDisplacementMap
        in="blur"
        in2="map"
        scale="0.4"
        xChannelSelector="R"
        yChannelSelector="G"
      />
    </filter>
  </defs>
</svg>
