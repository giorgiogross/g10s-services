---
interface Props {
  href: string;
  label?: string;
  class?: string;
}

const {
  href,
  label = "I have an idea, let's talk",
  class: className,
} = Astro.props;
---

<a href={href} class:list={["cta-btn", className]}>
  <span class="cta-btn__label">{label}</span>
  <span class="cta-btn__icon" aria-hidden="true">
    <img
      class="cta-btn__icon-img cta-btn__icon-img--closed"
      src="/phone-closed-white-48x48.svg"
      alt=""
      width="24"
      height="24"
      decoding="async"
      loading="lazy"
    />
    <img
      class="cta-btn__icon-img cta-btn__icon-img--open"
      src="/phone-open-white-48x48.svg"
      alt=""
      width="24"
      height="24"
      decoding="async"
      loading="lazy"
    />
  </span>
</a>
